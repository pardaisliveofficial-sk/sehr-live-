{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:frontend": "vite build",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "cap:copy": "cap copy",
    "cap:sync": "cap sync",
    "android": "cap open android",
    "android:prep": "npm run build && node android-recreate-icons.cjs && npx cap sync android",
    "android:build:apk": "npm run android:prep && cd android && ./gradlew assembleRelease",
    "android:build:aab": "npm run android:prep && cd android && ./gradlew bundleRelease",
    "android:build:debug": "npm run android:prep && cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1090.0",
    "@capacitor/core": "^8.4.2",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "agent-base": "6.0.2",
    "agora-rtc-sdk-ng": "^4.24.6",
    "agora-token": "^2.0.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.16.0",
    "firebase-admin": "^14.2.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.2.0",
    "node-fetch": "2.7.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
